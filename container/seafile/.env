# ── Seafile 13 · environment file ─────────────────────────────────────────────
# Copy this file to .env and fill in every value marked  ← CHANGE THIS

# ── Images ────────────────────────────────────────────────────────────────────
SEAFILE_IMAGE=docker.io/seafileltd/seafile-mc:13.0-latest
SEAFILE_DB_IMAGE=docker.io/mariadb:10.11
SEAFILE_REDIS_IMAGE=docker.io/redis:7

# ── Hostname & protocol ───────────────────────────────────────────────────────
# Use the public hostname or IP your users will reach Seafile on.
SEAFILE_SERVER_HOSTNAME=files.xinoi.net     # ← CHANGE THIS
SEAFILE_SERVER_PROTOCOL=https                    # change to https if you have TLS

# ── Database ──────────────────────────────────────────────────────────────────
# Root password is only used during first-time initialisation.
INIT_SEAFILE_MYSQL_ROOT_PASSWORD=changeme_root  # ← CHANGE THIS
SEAFILE_MYSQL_DB_USER=seafile
SEAFILE_MYSQL_DB_PASSWORD=changeme_seafile      # ← CHANGE THIS

# ── Redis cache ───────────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis                   # ← CHANGE THIS
CACHE_PROVIDER=redis
REDIS_HOST=redis
REDIS_PORT=6379

# ── First-run admin account ───────────────────────────────────────────────────
INIT_SEAFILE_ADMIN_EMAIL=zaunrithj@gmail.com      # ← CHANGE THIS
INIT_SEAFILE_ADMIN_PASSWORD=Mami-papi-123      # ← CHANGE THIS

# ── JWT key (generate with: openssl rand -hex 32) ────────────────────────────
JWT_PRIVATE_KEY=c07224b15e8c4546e8bba25c89d743a00786ed88804973d31d97f339d2061322             # ← CHANGE THIS

# ── Data paths ────────────────────────────────────────────────────────────────
SEAFILE_VOLUME=/mnt/data/seafile/seafile-data
SEAFILE_MYSQL_VOLUME=/mnt/data/seafile/db

# ── Timezone ──────────────────────────────────────────────────────────────────
TIME_ZONE=Europe/Berlin

# ── Optional features (disabled by default) ───────────────────────────────────
ENABLE_SEADOC=false
ENABLE_NOTIFICATION_SERVER=false
NON_ROOT=false
SEAFILE_LOG_TO_STDOUT=false
ENABLE_GO_FILESERVER=true
